# ============================================================
# Cloud Ops Dashboard — Configuration
# ============================================================
# 1. Copy this file:  cp .env.example backend/.env
# 2. Replace <placeholders> with your real credentials
# 3. Run:  docker compose up --build -d
# ============================================================

# === Huawei Cloud OBS (REQUIRED) ===
# These credentials let the backend read your cloud ops data from OBS.
OBS_AK=<your_obs_access_key>
OBS_SK=<your_obs_secret_key>
OBS_REGION=la-south-2
OBS_BUCKET=<your_bucket_name>
OBS_PREFIX=CloudOpsDemo/cloud-ops-demo-data

# === MaaS — AI Insights (OPTIONAL) ===
# If omitted, the dashboard works but the AI insights feature is disabled.
MAAS_API_KEY=<your_maas_api_key>
MAAS_MODEL=deepseek-v4-flash
MAAS_BASE_URL=https://api-ap-southeast-1.modelarts-maas.com/openai/v1

# === Application (OPTIONAL) ===
APP_HOST=0.0.0.0
APP_PORT=8000
CACHE_TTL_SECONDS=300
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
