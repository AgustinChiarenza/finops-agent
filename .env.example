# ============================================================
# FinOps Agent — root configuration
# ============================================================
# Copy to the service that needs it:
#   cp .env.example agent/.env
#   cp .env.example dashboard/backend/.env   (dashboard only needs OBS + MaaS vars)
# Fill <placeholders> with real credentials. Never commit a real .env.
# ============================================================

# === Cloud Ops Dashboard API (source of live FinOps data) ===
# In docker compose the dashboard backend is reachable at http://dashboard-backend:8000
DASHBOARD_API_BASE=http://dashboard-backend:8000
DASHBOARD_TIMEOUT_SECONDS=30

# === Huawei Cloud OBS (REQUIRED by the dashboard backend) ===
OBS_AK=<your_obs_access_key>
OBS_SK=<your_obs_secret_key>
OBS_REGION=la-south-2
OBS_BUCKET=<your_bucket_name>
OBS_PREFIX=CloudOpsDemo/cloud-ops-demo-data

# === MaaS — Huawei ModelArts Studio (OpenAI-compatible) ===
# Used by the LiteLLM orchestrator to route between multiple models.
MAAS_API_KEY=<your_maas_api_key>
MAAS_BASE_URL=https://api-ap-southeast-1.modelarts-maas.com/openai/v1

# === Embeddings (RAG) ===
# ollama = local Ollama (nomic-embed-text), like the uade-rag pattern.
# maas   = use a MaaS embedding model instead.
EMBED_PROVIDER=ollama
OLLAMA_HOST=http://ollama:11434
EMBED_MODEL=nomic-embed-text

# === RAG / vector store ===
CHROMA_DIR=agent/data/chroma_db
CHROMA_COLLECTION=finops_knowledge
KNOWLEDGE_DIR=agent/knowledge
RAG_TOP_K=6

# === LiteLLM orchestrator ===
# Default routing tier: cheap | standard | powerful
DEFAULT_TIER=standard
ORCHESTRATOR_TIMEOUT_SECONDS=180
MAX_TOKENS=4096
TEMPERATURE=0.2

# === Application ===
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8082
