# FinOps Agent — service-level env (copy to agent/.env)
# Root .env.example documents all variables; this is the subset the agent reads.

DASHBOARD_API_BASE=http://dashboard-backend:8000
DASHBOARD_TIMEOUT_SECONDS=30

MAAS_API_KEY=<your_maas_api_key>
MAAS_BASE_URL=https://api-ap-southeast-1.modelarts-maas.com/openai/v1

EMBED_PROVIDER=ollama
OLLAMA_HOST=http://ollama:11434
EMBED_MODEL=nomic-embed-text

CHROMA_DIR=agent/data/chroma_db
CHROMA_COLLECTION=finops_knowledge
KNOWLEDGE_DIR=agent/knowledge
RAG_TOP_K=6

DEFAULT_TIER=standard
ORCHESTRATOR_TIMEOUT_SECONDS=180
MAX_TOKENS=4096
TEMPERATURE=0.2

APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8082
